{
  "$schema": "https://schema.tauri.app/config/2.11.0/",
  "productName": "墨阅",
  "version": "0.1.0",
  "identifier": "com.abyss.reader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "墨阅",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "center": true,
        "decorations": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": "default-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/512x512.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "copyright": "Copyright © 2025 墨阅",
    "category": "public.app-category.reference",
    "shortDescription": "桌面端小说阅读器，兼容开源阅读书源",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["SimpChinese"]
      }
    }
  }
}

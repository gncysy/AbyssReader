{
    "compilerOptions":  {
                            "target":  "ES2020",
                            "module":  "ESNext",
                            "lib":  [
                                        "ES2020",
                                        "DOM",
                                        "DOM.Iterable"
                                    ],
                            "skipLibCheck":  true,
                            "esModuleInterop":  true,
                            "allowSyntheticDefaultImports":  true,
                            "strict":  true,
                            "noImplicitAny":  true,
                            "strictNullChecks":  true,
                            "strictFunctionTypes":  true,
                            "strictPropertyInitialization":  true,
                            "noImplicitThis":  true,
                            "alwaysStrict":  true,
                            "forceConsistentCasingInFileNames":  true,
                            "moduleResolution":  "node",
                            "resolveJsonModule":  true,
                            "isolatedModules":  true,
                            "noEmit":  true,
                            "baseUrl":  ".",
                            "paths":  {
                                          "@/*":  [
                                                      "src/renderer/*"
                                                  ],
                                          "@engine/*":  [
                                                            "src/engine/*"
                                                        ],
                                          "@shared/*":  [
                                                            "src/shared/*"
                                                        ]
                                      },
                            "types":  [
                                          "node",
                                          "vite/client"
                                      ],
                            "jsx":  "preserve"
                        },
    "include":  [
                    "src/**/*.ts",
                    "src/**/*.tsx",
                    "src/**/*.vue",
                    "src/**/*.d.ts",
                    "src/renderer/**/*.d.ts"
                ],
    "exclude":  [
                    "node_modules",
                    "dist",
                    "release"
                ]
}
